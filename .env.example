# LLM 配置（DeepSeek）
LLM_API_KEY=sk-your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Embedding 配置（硅基流动）
EMBEDDING_API_KEY=sk-your-siliconflow-api-key
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIM=1024

# Reranker（硅基流动，默认复用 Embedding Key）
# RERANKER_API_KEY=
# RERANKER_BASE_URL=https://api.siliconflow.cn/v1/rerank
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Langfuse 可观测性（docker compose 启动后，访问 http://localhost:3000 注册并创建项目获取 Key）
# 启动命令：cd rag-infra && docker compose -f docker-compose-Langfuse.yml up -d
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_HOST=http://localhost:3000

# 切分
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# 检索
TOP_K=5
